---
import CafeneaHero from '../components/cafenea/CafeneaHero.astro';
import ContactSection from '../components/cafenea/ContactSection.astro';
import EventsCarousel from '../components/cafenea/EventsCarousel.astro';
import LocationSection from '../components/cafenea/LocationSection.astro';
import MenuSection from '../components/cafenea/MenuSection.astro';
import Layout from '../layouts/Layout.astro';
import { contactInfo } from '../lib/contact';
import { loadQuery } from '../sanity/lib/load-query';

const today = new Date().toISOString().slice(0, 10);

const EVENTS_QUERY = `*[_type == "event" && date >= $today] | order(date asc){
	_id,
	title,
	"slug": slug.current,
	date,
	image {
		asset,
		alt
	}
}`;

const { data: events } = await loadQuery<
	{
		_id: string;
		title: string;
		slug: string;
		date: string;
		image: { asset: { _ref: string }; alt?: string };
	}[]
>({ query: EVENTS_QUERY, params: { today } });

type GalleryImage = { asset?: { _ref?: string }; alt?: string } | null;

const CAFENEA_QUERY = `*[_type == "cafeneaPage" && _id == "cafeneaPage"][0]{
	menuItems[]{
		_key,
		name,
		price
	},
	locationGallery {
		topLeft { asset, alt },
		topCenter { asset, alt },
		topRight { asset, alt },
		bottomLeft { asset, alt },
		bottomCenter { asset, alt },
		bottomRight { asset, alt }
	}
}`;

const { data: cafeneaPage } = await loadQuery<{
	menuItems?: { _key: string; name: string; price: number }[];
	locationGallery?: {
		topLeft?: GalleryImage;
		topCenter?: GalleryImage;
		topRight?: GalleryImage;
		bottomLeft?: GalleryImage;
		bottomCenter?: GalleryImage;
		bottomRight?: GalleryImage;
	};
} | null>({ query: CAFENEA_QUERY });

const cafeneaSchema = {
	'@context': 'https://schema.org',
	'@type': 'CafeOrCoffeeShop',
	name: 'Cafenea Noima',
	url: new URL('/cafenea', Astro.site ?? Astro.url).href,
	image: new URL('/og.jpeg', Astro.site ?? Astro.url).href,
	telephone: contactInfo.phone,
	email: contactInfo.email,
	priceRange: '$$',
	servesCuisine: ['Cafea de specialitate', 'Mic dejun', 'Brunch'],
	address: {
		'@type': 'PostalAddress',
		streetAddress: contactInfo.address.street,
		addressLocality: contactInfo.address.city,
		postalCode: contactInfo.address.postalCode,
		addressCountry: 'RO',
	},
	openingHoursSpecification: [
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: [
				'Monday',
				'Tuesday',
				'Wednesday',
				'Thursday',
				'Friday',
				'Saturday',
			],
			opens: '07:30',
			closes: '19:00',
		},
		{
			'@type': 'OpeningHoursSpecification',
			dayOfWeek: 'Sunday',
			opens: '09:00',
			closes: '15:00',
		},
	],
};
---

<Layout
	title="Cafenea de specialitate în Cluj — Prăjitoria Noima"
	description="Cafeneaua Noima pe Strada Bobâlnei 58, Cluj-Napoca. Cafea de specialitate, espresso, filtru și meniu zilnic. Deschis luni–sâmbătă 7:30–19:00, duminică 9:00–15:00."
	jsonLd={cafeneaSchema}
>
	<div class="cafenea-page">
		<CafeneaHero />
		<MenuSection items={cafeneaPage?.menuItems ?? []} />
		<EventsCarousel events={events ?? []} />
		<LocationSection gallery={cafeneaPage?.locationGallery} />
		<ContactSection />
	</div>
</Layout>

<style>
	.cafenea-page {
		background: var(--color-cream);
		/* The contact splash uses 130vw + negative margins to bleed past the viewport edge.
		   Clip horizontally so the document never becomes wider than the viewport — otherwise
		   the fixed header (sized via 100% - site-inset) gets pushed off the right side on
		   mobile, and sticky elements behave unpredictably. `clip` (vs `hidden`) doesn't
		   create a scroll container, so it doesn't break sticky in descendants. */
		overflow-x: clip;
	}
</style>
