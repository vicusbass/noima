---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Setări cookie-uri — Noima"
  description="Schimbă-ți preferințele privind cookie-urile pe Noima."
>
  <section class="container-x py-24 md:py-32 max-w-3xl">
    <h1 class="section-heading text-left mb-8">Setări cookie-uri</h1>

    <p class="text-[1rem] md:text-[1.0625rem] leading-[1.75] mb-10">
      Aici poți schimba oricând acordul pentru cookie-urile de analiză. Pentru
      detalii despre ce colectăm, vezi
      <a href="/politica-cookies" class="underline">politica de cookie-uri</a>.
    </p>

    <div class="border border-line rounded-2xl p-6 md:p-8 bg-cream">
      <div class="flex items-start justify-between gap-6 flex-col md:flex-row">
        <div>
          <h2 class="text-lg font-bold mb-2">Cookie-uri de analiză</h2>
          <p class="text-sm text-mute leading-relaxed">
            Google Analytics 4 cu IP anonimizat. Ne ajută să înțelegem cum este
            folosit site-ul. Fără publicitate, fără remarketing.
          </p>
        </div>
        <p class="text-sm font-medium" data-consent-status>
          Se încarcă…
        </p>
      </div>

      <div class="mt-6 flex flex-wrap gap-3">
        <button
          type="button"
          data-consent-action="granted"
          class="px-5 py-3 rounded-full bg-ink text-white text-xs font-medium tracking-wider uppercase hover:bg-tan hover:text-ink transition-colors"
        >
          Accept toate
        </button>
        <button
          type="button"
          data-consent-action="denied"
          class="px-5 py-3 rounded-full border border-ink text-ink text-xs font-medium tracking-wider uppercase hover:bg-ink hover:text-white transition-colors"
        >
          Doar necesare
        </button>
      </div>
    </div>
  </section>
</Layout>

<script>
  const STORAGE_KEY = 'noima:consent';

  const labels: Record<string, string> = {
    granted: 'Activ — datele sunt colectate',
    denied: 'Inactiv — refuzat',
    none: 'Nedefinit — banner-ul va apărea la următoarea vizită',
  };

  function refresh() {
    const status = document.querySelector<HTMLElement>('[data-consent-status]');
    if (!status) return;
    let value: string = 'none';
    try {
      value = localStorage.getItem(STORAGE_KEY) ?? 'none';
    } catch {}
    status.textContent = labels[value] ?? labels.none;
  }

  function init() {
    refresh();
    document
      .querySelectorAll<HTMLButtonElement>('[data-consent-action]')
      .forEach((btn) => {
        btn.addEventListener('click', () => {
          const value = btn.dataset.consentAction as 'granted' | 'denied';
          try {
            localStorage.setItem(STORAGE_KEY, value);
          } catch {}
          window.dispatchEvent(
            new CustomEvent('noima:consent-update', { detail: value }),
          );
          refresh();
        });
      });
  }

  document.addEventListener('astro:page-load', init);
</script>
