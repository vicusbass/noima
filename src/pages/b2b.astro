---
import { Image } from 'astro:assets';
import coffeeShopImg from '../assets/b2b/1.jpeg';
import officeImg from '../assets/b2b/2.jpeg';
import equipmentImg from '../assets/b2b/3.jpeg';
import BirouIcon from '../assets/b2b/birou.svg';
import EchipamentIcon from '../assets/b2b/echipament.svg';
import heroDecor from '../assets/b2b/hero.png';
import HomeIcon from '../assets/b2b/home.svg';
import Button from '../components/Button.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Parteneriate cu Sens — Prăjitoria Noima, Cluj"
  description="Parteneriate B2B Noima în Cluj: cafea de specialitate pentru cafenele și birouri, echipamente potrivite și consultanță pentru un serviciu constant."
>
  <!-- Hero -->
  <section class="relative">
    <div
      class="container-x pt-[calc(var(--header-height)+2.5rem)] pb-10 md:pt-[calc(var(--header-height)+4rem)] md:pb-6 lg:pt-[calc(var(--header-height)+5rem)]"
    >
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-8 md:gap-12 items-center"
      >
        <div
          class="flex justify-center md:block md:self-start md:relative md:h-72 lg:h-80"
        >
          <Image
            src={heroDecor}
            alt=""
            widths={[300, 500, 800]}
            sizes="(min-width: 1024px) 380px, (min-width: 768px) 320px, 260px"
            quality={90}
            format="webp"
            class="w-auto h-auto max-w-[260px] md:max-w-none md:absolute md:top-[-60px] md:left-0 md:z-50 lg:top-[-80px] md:h-[500px] lg:h-[580px] pointer-events-none"
            aria-hidden="true"
          />
        </div>

        <div>
          <h1 class="display text-[clamp(2.5rem,7vw,5rem)] mb-5 md:mb-6">
            Parteneriate<br />cu sens
          </h1>
          <p
            class="text-ink-soft text-[0.9375rem] md:text-[1.0625rem] leading-relaxed max-w-lg mb-8 md:mb-10"
          >
            La Noima, o cafea bună nu e un accident. Dacă și tu vrei să oferi
            clienților tăi o experiență cu sens, suntem gata să-ți oferim cafea,
            echipamente și consultanță.
          </p>
          <Button href="#contact" variant="dark">Contactează-ne</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation pills -->
  <nav class="bg-cream py-8 md:py-14">
    <div class="container-x flex flex-wrap justify-center gap-3">
      <a href="#cafenele" class="b2b-pill">
        <HomeIcon width={18} height={18} />
        Cafea pentru Cafenele
      </a>
      <a href="#birouri" class="b2b-pill">
        <BirouIcon width={18} height={18} />
        Cafea pentru Birouri
      </a>
      <a href="#echipamente" class="b2b-pill">
        <EchipamentIcon width={18} height={18} />
        Echipamente
      </a>
    </div>
  </nav>

  <!-- Section: Cafea pentru Cafenele -->
  <section id="cafenele" class="bg-cream grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130">
      <Image
        src={coffeeShopImg}
        alt="Interior cafenea cu atmosferă caldă"
        widths={[480, 768, 1200, 1600]}
        sizes="(min-width: 768px) 50vw, 100vw"
        quality={80}
        format="webp"
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20"
    >
      <HomeIcon class="mb-4" width={32} height={32} />
      <h2 class="b2b-heading">
        cafea<br />pentru<br /><span class="text-tan">cafenele</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Prăjim cafele de specialitate selectate pentru consistență, gust și
        poveste. Lucrăm cu parteneri care înțeleg că în spatele fiecărei cafele
        există o decizie luată cu sens.
      </p>
    </div>
  </section>

  <!-- Section: Cafea pentru Birouri -->
  <section id="birouri" class="bg-cream grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130 md:order-last">
      <Image
        src={officeImg}
        alt="Birou modern cu spațiu luminos"
        widths={[480, 768, 1200, 1600]}
        sizes="(min-width: 768px) 50vw, 100vw"
        quality={80}
        format="webp"
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20 md:order-first"
    >
      <BirouIcon class="mb-4" width={32} height={32} />
      <h2 class="b2b-heading">
        cafea<br />pentru<br /><span class="text-tan">birouri</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Pauza de cafea merită să fie un moment bun. Pentru asta am creat o cafea
        specială, echilibrată și ușor de preparat.
      </p>
    </div>
  </section>

  <!-- Section: Echipamente pentru Parteneri -->
  <section id="echipamente" class="bg-cream grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130">
      <Image
        src={equipmentImg}
        alt="Echipament barista — râșniță și espressor"
        widths={[480, 768, 1200, 1600]}
        sizes="(min-width: 768px) 50vw, 100vw"
        quality={80}
        format="webp"
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20"
    >
      <EchipamentIcon class="mb-4" width={32} height={32} />
      <h2 class="b2b-heading">
        echipamente<br />pentru<br /><span class="text-tan">parteneri</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Lucrăm cu branduri în care avem încredere și pe care le folosim noi
        înșine. Îți putem recomanda soluții potrivite pentru spațiul și volumul
        tău — fără să-ți vindem mai mult decât ai nevoie.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <div id="contact" class="bg-cream pt-14 md:pt-20 text-center">
    <h2 class="section-heading">hai să vorbim</h2>
  </div>
  <ContactForm showContactInfo={false} />
</Layout>

<style>
  .b2b-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.85rem 1.5rem;
    border: 1px solid var(--color-line-soft);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .b2b-pill:hover {
    border-color: var(--color-ink);
    background: var(--color-cream);
  }

  .b2b-heading {
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }

  .b2b-body {
    color: var(--color-ink-soft);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 28rem;
  }

  @media (min-width: 768px) {
    .b2b-body {
      font-size: 1.0625rem;
    }
  }
</style>
