---
import { Image } from 'astro:assets';
import heroDecor from '../assets/main/noima-square.png';
import Button from '../components/Button.astro';
import ContactForm from '../components/contact/ContactForm.astro';
import Layout from '../layouts/Layout.astro';

const coffeeShopImg =
	'https://images.unsplash.com/photo-1554118811-1e0d58224f24?w=1200&h=900&fit=crop&q=80';
const officeImg =
	'https://images.unsplash.com/photo-1497366216548-37526070297c?w=1200&h=900&fit=crop&q=80';
const equipmentImg =
	'https://images.unsplash.com/photo-1517701604599-bb29b565090c?w=1200&h=900&fit=crop&q=80';
---

<Layout title="Parteneriate cu Sens — Prăjitoria Noima, Cluj">
  <!-- Hero -->
  <section class="bg-cream">
    <div
      class="container-x pt-[calc(var(--header-height)+2rem)] pb-10 md:pt-[calc(var(--header-height)+4rem)] md:pb-16"
    >
      <div
        class="grid grid-cols-1 md:grid-cols-[1fr_1.5fr] gap-6 md:gap-12 items-center"
      >
        <div class="max-w-55 md:max-w-85">
          <Image
            src={heroDecor}
            alt=""
            widths={[400, 700]}
            sizes="(min-width: 768px) 340px, 220px"
            quality={90}
            format="webp"
            class="w-full h-auto"
            aria-hidden="true"
          />
        </div>

        <div>
          <h1 class="display text-[clamp(2.5rem,7vw,5rem)] mb-5 md:mb-6">
            Parteneriate<br />cu sens
          </h1>
          <p
            class="text-ink-soft text-[0.9375rem] md:text-[1.0625rem] leading-relaxed max-w-lg mb-8 md:mb-10"
          >
            La Noima, o cafea bună nu e un accident. Dacă și tu vrei să oferi
            clienților tăi o experiență cu sens, suntem gata să-ți oferim cafea,
            echipamente și consultanță.
          </p>
          <Button href="#contact" variant="dark">Contactează-ne</Button>
        </div>
      </div>
    </div>
  </section>

  <!-- Navigation pills -->
  <nav class="py-6 md:py-8">
    <div class="container-x flex flex-wrap justify-center gap-3">
      <a href="#cafenele" class="b2b-pill">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M17 8h1a4 4 0 0 1 0 8h-1"></path>
          <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
          <line x1="6" x2="6" y1="2" y2="4"></line>
          <line x1="10" x2="10" y1="2" y2="4"></line>
          <line x1="14" x2="14" y1="2" y2="4"></line>
        </svg>
        Cafea pentru Cafenele
      </a>
      <a href="#birouri" class="b2b-pill">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="m9 11 3 3L22 4"></path>
          <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
          ></path>
        </svg>
        Cafea pentru Birouri
      </a>
      <a href="#echipamente" class="b2b-pill">
        <svg
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect width="7" height="7" x="3" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="3" rx="1"></rect>
          <rect width="7" height="7" x="14" y="14" rx="1"></rect>
          <rect width="7" height="7" x="3" y="14" rx="1"></rect>
        </svg>
        Echipamente
      </a>
    </div>
  </nav>

  <!-- Section: Cafea pentru Cafenele -->
  <section id="cafenele" class="grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130">
      <img
        src={coffeeShopImg}
        alt="Interior cafenea cu atmosferă caldă"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20"
    >
      <svg
        class="mb-4 text-ink"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M17 8h1a4 4 0 0 1 0 8h-1"></path>
        <path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path>
        <line x1="6" x2="6" y1="2" y2="4"></line>
        <line x1="10" x2="10" y1="2" y2="4"></line>
        <line x1="14" x2="14" y1="2" y2="4"></line>
      </svg>
      <h2 class="b2b-heading">
        cafea<br />pentru<br /><span class="text-tan">cafenele</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Prăjim cafele de specialitate selectate pentru consistență, gust și
        poveste. Lucrăm cu parteneri care înțeleg că în spatele fiecărei cafele
        există o decizie luată cu sens.
      </p>
    </div>
  </section>

  <!-- Section: Cafea pentru Birouri -->
  <section id="birouri" class="grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130 md:order-last">
      <img
        src={officeImg}
        alt="Birou modern cu spațiu luminos"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20 md:order-first"
    >
      <svg
        class="mb-4 text-ink"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="m9 11 3 3L22 4"></path>
        <path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"
        ></path>
      </svg>
      <h2 class="b2b-heading">
        cafea<br />pentru<br /><span class="text-tan">birouri</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Pauza de cafea merită să fie un moment bun. Pentru asta am creat o cafea
        specială, echilibrată și ușor de preparat.
      </p>
    </div>
  </section>

  <!-- Section: Echipamente pentru Parteneri -->
  <section id="echipamente" class="grid grid-cols-1 md:grid-cols-2">
    <div class="aspect-4/3 md:aspect-auto md:min-h-130">
      <img
        src={equipmentImg}
        alt="Echipament barista — râșniță și espressor"
        class="w-full h-full object-cover"
        loading="lazy"
      />
    </div>
    <div
      class="flex flex-col justify-center px-6 py-10 md:px-12 md:py-16 lg:px-20"
    >
      <svg
        class="mb-4 text-ink"
        width="28"
        height="28"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="7" height="7" x="3" y="3" rx="1"></rect>
        <rect width="7" height="7" x="14" y="3" rx="1"></rect>
        <rect width="7" height="7" x="14" y="14" rx="1"></rect>
        <rect width="7" height="7" x="3" y="14" rx="1"></rect>
      </svg>
      <h2 class="b2b-heading">
        echipamente<br />pentru<br /><span class="text-tan">parteneri</span>
      </h2>
      <p class="b2b-body mt-5 md:mt-6">
        Lucrăm cu branduri în care avem încredere și pe care le folosim noi
        înșine. Îți putem recomanda soluții potrivite pentru spațiul și volumul
        tău — fără să-ți vindem mai mult decât ai nevoie.
      </p>
    </div>
  </section>

  <!-- Contact -->
  <div id="contact" class="bg-cream pt-14 md:pt-20 text-center">
    <h2 class="section-heading">hai să vorbim</h2>
  </div>
  <ContactForm showContactInfo={false} />
</Layout>

<style>
  .b2b-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    border: 1px solid var(--color-line-soft);
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: none;
    white-space: nowrap;
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;
  }

  .b2b-pill:hover {
    border-color: var(--color-ink);
    background: var(--color-cream);
  }

  .b2b-heading {
    font-weight: 700;
    font-size: clamp(1.75rem, 4vw, 3rem);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-ink);
  }

  .b2b-body {
    color: var(--color-ink-soft);
    font-size: 0.9375rem;
    line-height: 1.7;
    max-width: 28rem;
  }

  @media (min-width: 768px) {
    .b2b-body {
      font-size: 1.0625rem;
    }
  }
</style>
