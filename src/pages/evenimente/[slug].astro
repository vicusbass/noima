---
import type { PortableTextBlock } from '@portabletext/types';
import { PortableText } from 'astro-portabletext';
import Button from '../../components/Button.astro';
import Layout from '../../layouts/Layout.astro';
import { contactInfo } from '../../lib/contact';
import { urlFor } from '../../sanity/lib/image';
import { loadQuery } from '../../sanity/lib/load-query';

type EventDoc = {
	title: string;
	slug: { current: string };
	date: string;
	image?: {
		asset: { _ref: string };
		alt?: string;
	};
	description?: PortableTextBlock[];
	summary?: string;
};

export async function getStaticPaths() {
	const { data } = await loadQuery<{ slug: string }[]>({
		query: `*[_type == "event" && defined(slug.current)]{ "slug": slug.current }`,
	});

	return (data ?? []).map(({ slug }) => ({ params: { slug } }));
}

const { slug } = Astro.params;

const { data: event } = await loadQuery<EventDoc | null>({
	query: `*[_type == "event" && slug.current == $slug][0]{
		title,
		slug,
		date,
		image { asset, alt },
		description,
		"summary": pt::text(description)
	}`,
	params: { slug },
});

if (!event) {
	return Astro.redirect('/404');
}

const [year, month, day] = event.date.split('-');
const formattedDate = `${day}.${month}.${year}`;

const IMAGE_WIDTHS = [320, 480, 640, 768, 960, 1200];

function buildEventImage(image: NonNullable<EventDoc['image']>, width: number) {
	return urlFor(image)
		.width(width)
		.height(width)
		.fit('crop')
		.auto('format')
		.quality(75)
		.url();
}

const eventImage = event.image?.asset ? event.image : undefined;
const imageSrc = eventImage ? buildEventImage(eventImage, 768) : undefined;
const imageSrcSet = eventImage
	? IMAGE_WIDTHS.map((w) => `${buildEventImage(eventImage, w)} ${w}w`).join(
			', ',
		)
	: undefined;

const truncate = (s: string, n: number) =>
	s.length <= n ? s : `${s.slice(0, n - 1).trimEnd()}…`;

const eventDescription = event.summary
	? truncate(event.summary, 160)
	: `${event.title} — eveniment la Cafeneaua Noima, Cluj-Napoca, pe ${formattedDate}.`;

const eventSchema = {
	'@context': 'https://schema.org',
	'@type': 'Event',
	name: event.title,
	startDate: event.date,
	eventStatus: 'https://schema.org/EventScheduled',
	eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
	description: event.summary ?? eventDescription,
	image: imageSrc ? new URL(imageSrc, Astro.site ?? Astro.url).href : undefined,
	location: {
		'@type': 'Place',
		name: 'Cafenea Noima',
		address: {
			'@type': 'PostalAddress',
			streetAddress: contactInfo.address.street,
			addressLocality: contactInfo.address.city,
			postalCode: contactInfo.address.postalCode,
			addressCountry: 'RO',
		},
	},
	organizer: {
		'@type': 'Organization',
		name: 'Noima',
		url: new URL('/', Astro.site ?? Astro.url).href,
	},
};
---

<Layout
	title={`${event.title} — Noima Cluj`}
	description={eventDescription}
	jsonLd={eventSchema}
>
	<article class="bg-cream pt-(--header-height)">
		<div class="container-x pt-14 pb-16 md:pt-28 md:pb-24">
			<div
				class="grid grid-cols-1 gap-8 md:grid-cols-[7fr_13fr] md:items-center md:gap-28"
			>
				<div class="mx-0 w-full max-w-[22rem] md:w-auto md:max-w-none">
					{
						imageSrc ? (
							<img
								src={imageSrc}
								srcset={imageSrcSet}
								sizes="(min-width: 768px) 35vw, min(22rem, 90vw)"
								alt={event.image?.alt || event.title}
								width="1600"
								height="1600"
								loading="eager"
								decoding="async"
								fetchpriority="high"
								class="block aspect-square h-auto w-full object-cover"
							/>
						) : (
							<div class="event-image-placeholder grain block aspect-square h-auto w-full" />
						)
					}
				</div>

				<div class="flex flex-col gap-6 md:gap-8">
					<p class="text-[1.0625rem] md:text-[1.125rem] font-medium tracking-[0.02em] text-coffee">
						{formattedDate}
					</p>
					<h1
						class="display text-[clamp(2.25rem,3.4375vw,4.125rem)] leading-[1.05]! text-ink max-w-[16ch]"
						transition:name={`event-title-${slug}`}
					>
						{event.title}
					</h1>
					{
						event.description && (
							<div class="event-description text-base leading-[1.7] text-ink flex flex-col gap-5 md:text-[1.0625rem] md:max-w-[48ch]">
								<PortableText value={event.description} />
							</div>
						)
					}
					<Button href="/contact#formular" variant="dark" class="self-start mt-4">
						REZERVĂ UN LOC
					</Button>
				</div>
			</div>
		</div>
	</article>
</Layout>

<style>
	.event-image-placeholder {
		background: linear-gradient(135deg, #2a241f, #15110d);
		position: relative;
	}

	.event-description :global(p) {
		margin: 0;
	}

	.event-description :global(a) {
		color: var(--color-ink);
		text-decoration: underline;
	}

	.event-description :global(h1),
	.event-description :global(h2),
	.event-description :global(h3),
	.event-description :global(h4) {
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
	}

	.event-description :global(ul),
	.event-description :global(ol) {
		padding-left: 1.25rem;
		margin: 0;
	}
</style>
