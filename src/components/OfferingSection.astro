---
import { Image } from 'astro:assets';
import NoimaSquare from '../assets/main/noima-square.png';

interface Props {
	headingTop?: string;
	headingBottom?: string;
	leftText?: string;
	rightText?: string;
}

const {
	headingTop = 'ce primește omul',
	headingBottom = 'la noima',
	leftText = 'La noi(ma) găsești cafea de specialitate, din loturi limitate, aleasă cu grijă și prăjită local, după gustul tău.',
	rightText = 'La noima, fiecare barista știe totul despre cafeaua pe care ți-o pregătește și e gata să-ți spună și ție povestea.',
} = Astro.props;
---

<section id="offering" class="py-16 md:py-24">
	<div class="container-x">
		<h2 class="section-heading mb-6 md:mb-16">
			<span>{headingTop}</span>
			<span>{headingBottom}</span>
		</h2>
	</div>

	<div class="container-x">
		<div
			class="flex flex-col items-center gap-8 md:flex-row md:justify-between md:gap-12 md:bg-[#f8f5ed] md:min-h-[420px] md:px-20 md:py-16"
		>
			<p
				class="body-copy max-w-[50ch] text-center md:flex-1 md:max-w-[32ch] md:text-right"
			>
				{leftText}
			</p>

			<div class="flex items-center justify-center md:flex-none">
				<Image
					src={NoimaSquare}
					alt=""
					widths={[240, 360, 480, 720]}
					sizes="(min-width: 768px) 320px, 60vw"
					class="block h-auto w-[60vw] max-w-[320px] md:w-[320px] md:max-w-none"
				/>
			</div>

			<p
				class="body-copy max-w-[50ch] text-center md:flex-1 md:max-w-[32ch] md:text-left"
			>
				{rightText}
			</p>
		</div>
	</div>
</section>
