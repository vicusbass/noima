---
import { urlFor } from '../../sanity/lib/image';

interface EventItem {
	_id: string;
	title: string;
	slug: string;
	date: string;
	image: {
		asset: { _ref: string };
		alt?: string;
	};
}

interface Props {
	heading?: string;
	events: EventItem[];
}

const { heading = 'evenimente', events } = Astro.props;
---

{
	events.length > 0 && (
		<section class="py-16 md:py-24">
			<div class="container-x">
				<h2 class="section-heading mb-10 md:mb-14">{heading}</h2>
			</div>

			<div class="relative" data-events-carousel data-count={events.length}>
				<div
					class="flex gap-5 overflow-x-auto snap-x snap-mandatory scroll-smooth [-webkit-overflow-scrolling:touch] [scrollbar-width:none] [&::-webkit-scrollbar]:hidden px-[calc(var(--site-inset)+var(--container-pad-sm))] md:px-[calc(var(--site-inset)+var(--container-pad-md))] xl:px-[calc(var(--site-inset)+var(--container-pad-lg))]"
					data-events-track
				>
					{events.map((event, i) => (
						<a
							href={`/evenimente/${event.slug}`}
							class="group relative flex-[0_0_100%] snap-start overflow-hidden no-underline text-white isolate aspect-4/3 md:aspect-square md:flex-[0_0_calc((100%-2*1.25rem)/3)]"
							data-card-index={i}
						>
							<img
								src={urlFor(event.image)
									.width(900)
									.height(900)
									.fit('crop')
									.auto('format')
									.url()}
								alt={event.image.alt || ''}
								loading={i < 3 ? 'eager' : 'lazy'}
								class="absolute inset-0 block h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.04] group-focus-visible:scale-[1.04]"
							/>
							<div
								class="absolute inset-0 z-1 [background:linear-gradient(to_bottom,rgba(0,0,0,0.15)_0%,rgba(0,0,0,0.25)_40%,rgba(0,0,0,0.6)_100%)]"
								aria-hidden="true"
							/>
							<h3
								class="display absolute top-12 left-10 right-10 z-2 text-[clamp(1.5rem,2.4vw,2.25rem)] font-semibold text-white max-w-[14ch]"
								transition:name={`event-title-${event.slug}`}
							>
								{event.title}
							</h3>
							<span class="absolute bottom-6 left-10 z-2 text-[0.8125rem] font-bold uppercase tracking-[0.12em] text-white underline underline-offset-4">
								VEZI EVENIMENTUL
							</span>
						</a>
					))}
				</div>

				{events.length > 1 && (
					<>
						<button
							type="button"
							class="absolute top-1/2 left-2 z-3 grid h-11 w-11 -translate-y-1/2 cursor-pointer place-items-center rounded-full border border-black/8 bg-white/85 text-black transition-colors hover:bg-white xl:left-6"
							data-events-prev
							aria-label="Evenimentul anterior"
						>
							<svg
								width="14"
								height="14"
								viewBox="0 0 14 14"
								fill="currentColor"
								aria-hidden="true"
							>
								<path d="M14 0v14L0 7z" />
							</svg>
						</button>
						<button
							type="button"
							class="absolute top-1/2 right-2 z-3 grid h-11 w-11 -translate-y-1/2 cursor-pointer place-items-center rounded-full border border-black/8 bg-white/85 text-black transition-colors hover:bg-white xl:right-6"
							data-events-next
							aria-label="Evenimentul următor"
						>
							<svg
								width="14"
								height="14"
								viewBox="0 0 14 14"
								fill="currentColor"
								aria-hidden="true"
							>
								<path d="M0 0v14l14-7z" />
							</svg>
						</button>
					</>
				)}
			</div>

			{events.length > 1 && (
				<div
					class="mt-8 flex justify-center gap-2"
					role="tablist"
					aria-label="Selectează evenimentul"
					data-events-dots
				>
					{events.map((event, i) => (
						<button
							type="button"
							class="h-2.5 w-2.5 cursor-pointer rounded-full border-0 bg-black/20 p-0 transition-colors data-[active=true]:bg-black/75"
							data-events-dot={i}
							data-active={i === 0 ? 'true' : 'false'}
							role="tab"
							aria-selected={i === 0 ? 'true' : 'false'}
							aria-label={`Eveniment ${i + 1}: ${event.title}`}
						/>
					))}
				</div>
			)}
		</section>
	)
}

<script>
	function initEventsCarousels() {
		const carousels = document.querySelectorAll<HTMLElement>(
			'[data-events-carousel]',
		);

		for (const carousel of carousels) {
			if (carousel.dataset.eventsCarouselReady === 'true') continue;
			carousel.dataset.eventsCarouselReady = 'true';

			const track = carousel.querySelector<HTMLElement>('[data-events-track]');
			const cards = Array.from(
				carousel.querySelectorAll<HTMLElement>('[data-card-index]'),
			);
			const prev = carousel.querySelector<HTMLButtonElement>(
				'[data-events-prev]',
			);
			const next = carousel.querySelector<HTMLButtonElement>(
				'[data-events-next]',
			);
			const section = carousel.closest('section');
			const dots = section
				? Array.from(
						section.querySelectorAll<HTMLButtonElement>('[data-events-dot]'),
					)
				: [];

			if (!track || cards.length === 0) continue;

			function scrollToCard(index: number) {
				const target = cards[index];
				if (!target || !track) return;
				const offset = target.offsetLeft - track.offsetLeft;
				track.scrollTo({ left: offset, behavior: 'smooth' });
			}

			function getCurrentIndex() {
				if (!track) return 0;
				const scrollLeft = track.scrollLeft;
				let closest = 0;
				let minDist = Infinity;
				cards.forEach((card, i) => {
					const dist = Math.abs(card.offsetLeft - track.offsetLeft - scrollLeft);
					if (dist < minDist) {
						minDist = dist;
						closest = i;
					}
				});
				return closest;
			}

			function syncDots() {
				const i = getCurrentIndex();
				dots.forEach((dot, di) => {
					const active = di === i;
					dot.dataset.active = active ? 'true' : 'false';
					dot.setAttribute('aria-selected', active ? 'true' : 'false');
				});
			}

			prev?.addEventListener('click', () => {
				scrollToCard(Math.max(0, getCurrentIndex() - 1));
			});
			next?.addEventListener('click', () => {
				scrollToCard(Math.min(cards.length - 1, getCurrentIndex() + 1));
			});
			dots.forEach((dot, i) =>
				dot.addEventListener('click', () => scrollToCard(i)),
			);

			let scrollTimeout: number | undefined;
			track.addEventListener('scroll', () => {
				if (scrollTimeout) window.clearTimeout(scrollTimeout);
				scrollTimeout = window.setTimeout(syncDots, 80);
			});

			syncDots();
		}
	}

	initEventsCarousels();
	document.addEventListener('astro:page-load', initEventsCarousels);
</script>
