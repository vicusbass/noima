---
import { Image } from 'astro:assets';
import splashImg from '../../assets/cafenea/splash.png';
import { contactInfo } from '../../lib/contact';
---

<section id="contact" class="pt-0 pb-12 md:pb-20">
	<div class="container-x">
		<div
			class="grid grid-cols-1 items-center gap-6 md:grid-cols-[minmax(0,1.2fr)_minmax(0,1fr)] md:gap-16"
		>
			<div
				class="relative z-2 -mt-32 -ml-[calc(var(--container-pad-sm)+var(--site-inset)+2rem)] -mr-[var(--container-pad-sm)] flex justify-start md:-mt-48 md:-ml-[calc(var(--container-pad-md)+var(--site-inset)-1.5rem)] md:mr-0"
			>
				<Image
					src={splashImg}
					alt=""
					class="block h-auto w-[130vw] max-w-[640px] md:w-full md:max-w-[720px]"
					loading="lazy"
				/>
			</div>

			<dl class="m-0 flex flex-col gap-6 p-0">
				<div class="border-b border-line-soft pb-4 last:border-b-0 last:pb-0">
					<dt class="mb-3 text-sm font-bold uppercase tracking-[0.18em] md:text-[0.9rem]">
						email
					</dt>
					<dd class="m-0 text-base leading-[1.6] md:text-[1.0625rem]">
						<a
							href={`mailto:${contactInfo.email}`}
							class="text-inherit no-underline transition-opacity hover:opacity-70"
						>
							{contactInfo.email}
						</a>
					</dd>
				</div>
				<div class="border-b border-line-soft pb-4 last:border-b-0 last:pb-0">
					<dt class="mb-3 text-sm font-bold uppercase tracking-[0.18em] md:text-[0.9rem]">
						telefon
					</dt>
					<dd class="m-0 text-base leading-[1.6] md:text-[1.0625rem]">
						<a
							href={contactInfo.phoneHref}
							class="text-inherit no-underline transition-opacity hover:opacity-70"
						>
							{contactInfo.phone}
						</a>
					</dd>
				</div>
				<div class="border-b border-line-soft pb-4 last:border-b-0 last:pb-0">
					<dt class="mb-3 text-sm font-bold uppercase tracking-[0.18em] md:text-[0.9rem]">
						program
					</dt>
					<dd class="m-0 text-base leading-[1.6] md:text-[1.0625rem]">
						{
							contactInfo.hours.map((h) => (
								<div>
									{h.days}: {h.time}
								</div>
							))
						}
					</dd>
				</div>
			</dl>
		</div>
	</div>
</section>
