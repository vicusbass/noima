---
import { Image } from 'astro:assets';
import splashImg from '../../assets/cafenea/splash.png';
import { contactInfo } from '../../lib/contact';
---

<section id="contact" class="contact-section">
	<div class="container-x">
		<div class="contact-layout">
			<div class="contact-image-wrap">
				<Image
					src={splashImg}
					alt=""
					class="contact-image"
					loading="lazy"
				/>
			</div>

			<dl class="contact-details">
				<div class="contact-row">
					<dt>email</dt>
					<dd>
						<a href={`mailto:${contactInfo.email}`}>{contactInfo.email}</a>
					</dd>
				</div>
				<div class="contact-row">
					<dt>telefon</dt>
					<dd>
						<a href={contactInfo.phoneHref}>{contactInfo.phone}</a>
					</dd>
				</div>
				<div class="contact-row">
					<dt>program</dt>
					<dd>
						{
							contactInfo.hours.map((h) => (
								<div>
									{h.days}: {h.time}
								</div>
							))
						}
					</dd>
				</div>
			</dl>
		</div>
	</div>
</section>

<style>
	.contact-section {
		background: transparent;
		padding-top: 0;
		padding-bottom: 3rem;
	}

	@media (min-width: 768px) {
		.contact-section {
			padding-bottom: 5rem;
		}
	}

	.contact-layout {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1.5rem;
		align-items: center;
	}

	.contact-image-wrap {
		display: flex;
		justify-content: flex-start;
		/* Overlap upward into the section above and break out of the container's left padding.
		   Position + z-index keep the splash painted ON TOP of the location grid. */
		position: relative;
		z-index: 2;
		margin-top: -8rem;
		margin-left: calc(-1 * var(--container-pad-sm) - var(--site-inset) - 2rem);
		margin-right: calc(-1 * var(--container-pad-sm));
	}

	@media (min-width: 768px) {
		.contact-image-wrap {
			margin-top: -6rem;
			margin-left: calc(-1 * var(--container-pad-md) - var(--site-inset) + 1.5rem);
			margin-right: calc(-1 * var(--container-pad-md));
		}
	}

	.contact-image {
		width: 130vw;
		max-width: 640px;
		height: auto;
		display: block;
	}

	.contact-details {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.contact-row {
		padding-bottom: 1rem;
		border-bottom: 1px solid var(--color-line-soft);
	}

	.contact-row:last-child {
		border-bottom: none;
		padding-bottom: 0;
	}

	.contact-row dt {
		font-weight: 700;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		font-size: 0.875rem;
		margin-bottom: 0.75rem;
	}

	.contact-row dd {
		margin: 0;
		font-size: 1rem;
		line-height: 1.6;
	}

	.contact-row a {
		color: inherit;
		text-decoration: none;
		transition: opacity 0.2s ease;
	}

	.contact-row a:hover {
		opacity: 0.7;
	}

	@media (min-width: 768px) {
		.contact-layout {
			grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
			gap: 4rem;
		}

		.contact-image-wrap {
			/* Pull image upward into the location grid and beyond the left edge */
			margin-top: -12rem;
			margin-left: calc(-1 * var(--container-pad-lg) - var(--site-inset) + 2rem);
			margin-right: 0;
		}

		.contact-image {
			width: 100%;
			max-width: 720px;
		}

		.contact-row dt {
			font-size: 0.9rem;
		}

		.contact-row dd {
			font-size: 1.0625rem;
		}
	}
</style>
