---
import { urlFor } from '../../sanity/lib/image';

type SanityImage =
	| {
			asset?: { _ref?: string };
			alt?: string;
	  }
	| null
	| undefined;

interface Props {
	gallery?: {
		topLeft?: SanityImage;
		topCenter?: SanityImage;
		topRight?: SanityImage;
		bottomLeft?: SanityImage;
		bottomCenter?: SanityImage;
		bottomRight?: SanityImage;
	};
}

const { gallery } = Astro.props;

type Shape = 'square' | 'wide';

interface Slot {
	key: string;
	shape: Shape;
	gridArea: string;
	sanity: SanityImage;
}

const slots: Slot[] = [
	{
		key: 'topLeft',
		shape: 'square',
		gridArea: '1 / 1 / 2 / 4',
		sanity: gallery?.topLeft,
	},
	{
		key: 'topCenter',
		shape: 'wide',
		gridArea: '1 / 4 / 2 / 10',
		sanity: gallery?.topCenter,
	},
	{
		key: 'topRight',
		shape: 'square',
		gridArea: '1 / 10 / 2 / 13',
		sanity: gallery?.topRight,
	},
	{
		key: 'bottomLeft',
		shape: 'square',
		gridArea: '2 / 1 / 3 / 4',
		sanity: gallery?.bottomLeft,
	},
	{
		key: 'bottomCenter',
		shape: 'square',
		gridArea: '2 / 4 / 3 / 7',
		sanity: gallery?.bottomCenter,
	},
	{
		key: 'bottomRight',
		shape: 'wide',
		gridArea: '2 / 7 / 3 / 13',
		sanity: gallery?.bottomRight,
	},
];

const allSlotsFilled = slots.every((s) => Boolean(s.sanity?.asset?._ref));

function buildSanityUrl(img: SanityImage, shape: Shape) {
	const ratio = shape === 'wide' ? [1600, 800] : [800, 800];
	return urlFor(img as never)
		.width(ratio[0])
		.height(ratio[1])
		.fit('crop')
		.auto('format')
		.url();
}
---

{
	allSlotsFilled && (
		<section class="py-16 md:py-24">
			<div class="container-x">
				<h2 class="section-heading mb-10 md:mb-14">locație</h2>

				<div class="grid grid-cols-1 gap-3 md:grid-cols-12 md:gap-4">
					{slots.map((slot) => (
						<div
							class="relative overflow-hidden data-[shape=square]:aspect-square data-[shape=wide]:aspect-2/1 md:data-[shape=wide]:aspect-auto md:[grid-area:var(--ga)]"
							data-shape={slot.shape}
							style={`--ga: ${slot.gridArea};`}
						>
							<img
								src={buildSanityUrl(slot.sanity, slot.shape)}
								alt={slot.sanity?.alt || ''}
								loading="lazy"
								class="absolute inset-0 block h-full w-full object-cover"
							/>
						</div>
					))}
				</div>
			</div>
		</section>
	)
}
