---
const GA_ID = 'G-EK91FRSZP5';
const enabled = import.meta.env.PROD;
---

{
	enabled && (
		<>
			<script
				is:inline
				async
				src={`https://www.googletagmanager.com/gtag/js?id=${GA_ID}`}
			/>
			<script is:inline define:vars={{ GA_ID }}>
				window.dataLayer = window.dataLayer || [];
				window.gtag = function () {
					window.dataLayer.push(arguments);
				};

				// Consent Mode v2 — default to denied until user accepts.
				window.gtag('consent', 'default', {
					ad_storage: 'denied',
					ad_user_data: 'denied',
					ad_personalization: 'denied',
					analytics_storage: 'denied',
					wait_for_update: 500,
				});

				// Apply previously stored choice on subsequent visits.
				try {
					var stored = localStorage.getItem('noima:consent');
					if (stored === 'granted') {
						window.gtag('consent', 'update', { analytics_storage: 'granted' });
					}
				} catch (err) {}

				window.gtag('js', new Date());
				// Disable auto page_view; we fire it on `astro:page-load` so view
				// transitions are tracked correctly without double-counting.
				window.gtag('config', GA_ID, {
					send_page_view: false,
					anonymize_ip: true,
				});

				function sendPageView() {
					if (typeof window.gtag !== 'function') return;
					window.gtag('event', 'page_view', {
						page_title: document.title,
						page_location: window.location.href,
						page_path: window.location.pathname + window.location.search,
						send_to: GA_ID,
					});
				}

				document.addEventListener('astro:page-load', sendPageView);

				window.addEventListener('noima:consent-update', function (e) {
					var granted = e.detail === 'granted';
					window.gtag('consent', 'update', {
						analytics_storage: granted ? 'granted' : 'denied',
					});
					if (granted) sendPageView();
				});
			</script>
		</>
	)
}
