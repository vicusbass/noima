---
import { Image } from 'astro:assets';
import HeroStain from '../../assets/contact/hero.png';
import { contactInfo } from '../../lib/contact';

const { address } = contactInfo;

const mapQuery = encodeURIComponent(
	`${address.street}, ${address.city}, ${address.postalCode}`,
);
const mapEmbedUrl = `https://www.google.com/maps?q=${mapQuery}&output=embed`;
const mapLinkUrl = `https://www.google.com/maps/search/?api=1&query=${mapQuery}`;
---

<section
	class="bg-surface pt-[calc(var(--header-height)+2.5rem)] pb-12 md:pt-[calc(var(--header-height)+4rem)] md:pb-20"
>
	<div
		class="container-x grid grid-cols-1 items-start gap-10 md:grid-cols-[1.1fr_1fr] md:items-center md:gap-16"
	>
		<div class="flex justify-start">
			<h1 class="sr-only">Contact</h1>
			<Image
				src={HeroStain}
				alt=""
				widths={[600, 900, 1200, 1801]}
				sizes="(min-width: 768px) 55vw, 100vw"
				quality={90}
				format="webp"
				class="block h-auto w-full max-w-[36rem] md:max-w-full"
				aria-hidden="true"
			/>
		</div>

		<div>
			<h2
				class="section-heading mb-5 text-left text-[clamp(1.6rem,4vw,2.5rem)] md:mb-7 md:text-[clamp(2rem,3vw,3rem)]"
			>
				unde ne găsești
			</h2>

			<div class="w-full overflow-hidden border border-line-soft bg-cream">
				<iframe
					class="block aspect-4/3 h-auto w-full border-0"
					src={mapEmbedUrl}
					title={`Hartă cu locația prăjitoriei Noima — ${address.street}, ${address.city}`}
					loading="lazy"
					referrerpolicy="no-referrer-when-downgrade"
					allowfullscreen></iframe>
				<a
					class="block border-t border-line-soft px-3.5 py-2.5 text-right text-[0.8125rem] uppercase tracking-[0.04em] text-ink no-underline hover:underline focus-visible:underline"
					href={mapLinkUrl}
					target="_blank"
					rel="noopener noreferrer"
				>
					Deschide în Google Maps →
				</a>
			</div>

			<address
				class="mt-5 grid grid-cols-[auto_1fr] gap-x-8 gap-y-4 text-[0.9375rem] not-italic text-ink md:mt-6 md:text-base md:justify-between"
			>
				<p class="font-bold uppercase tracking-[0.06em]">Adresa:</p>
				<p class="flex flex-col gap-1 md:text-right">
					<span>{address.street}</span>
					<span>{address.city}, {address.postalCode}</span>
				</p>
			</address>
		</div>
	</div>
</section>
