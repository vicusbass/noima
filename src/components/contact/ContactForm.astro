---
import { contactInfo } from '../../lib/contact';

const { email, phone, phoneHref, hours } = contactInfo;
---

<section class="contact-form-section">
	<div class="container-x contact-form-grid">
		<div class="contact-form-side">
			<h2 class="section-heading contact-form-heading">trimite-ne un mesaj</h2>

			<div class="contact-form-shell" data-form-shell>
				<form
					class="contact-form"
					data-contact-form
					method="post"
					action="/api/contact"
					novalidate
				>
					<!-- Honeypot: hidden from humans, bots fill it. -->
					<div class="hp-field" aria-hidden="true">
						<label>
							Lasă acest câmp gol
							<input
								type="text"
								name="website"
								tabindex="-1"
								autocomplete="off"
							/>
						</label>
					</div>

					<input type="hidden" name="renderedAt" data-rendered-at value="" />

					<div class="field">
						<label class="sr-only" for="contact-name">
							Nume & Prenume
						</label>
						<input
							id="contact-name"
							name="name"
							type="text"
							required
							autocomplete="name"
							placeholder="Nume & Prenume"
						/>
					</div>

					<div class="field">
						<label class="sr-only" for="contact-email">Email</label>
						<input
							id="contact-email"
							name="email"
							type="email"
							required
							autocomplete="email"
							placeholder="Email"
						/>
					</div>

					<div class="field">
						<label class="sr-only" for="contact-phone">
							Nr. de telefon
						</label>
						<input
							id="contact-phone"
							name="phone"
							type="tel"
							inputmode="tel"
							autocomplete="tel"
							placeholder="Nr. de telefon"
						/>
					</div>

					<div class="field">
						<label class="sr-only" for="contact-subject">Subiect</label>
						<input
							id="contact-subject"
							name="subject"
							type="text"
							placeholder="Subiect"
						/>
					</div>

					<div class="field">
						<label class="sr-only" for="contact-message">
							Mesajul tău
						</label>
						<textarea
							id="contact-message"
							name="message"
							required
							rows="5"
							placeholder="Mesajul tău"></textarea>
					</div>

					<p class="contact-error" data-form-error hidden>
						Mesajul nu s-a trimis. Te rugăm să încerci din nou sau scrie-ne
						direct la <a href={`mailto:${email}`}>{email}</a>.
					</p>

					<button type="submit" class="contact-submit" data-submit-btn>
						<span data-btn-label>Trimite</span>
					</button>
				</form>

				<div
					class="contact-success"
					data-success
					hidden
					role="status"
					aria-live="polite"
				>
					<h3 class="contact-success-title">Mulțumim!</h3>
					<p class="contact-success-text">
						Mesajul tău a ajuns la noi. Te contactăm în curând.
					</p>
				</div>
			</div>
		</div>

		<aside class="contact-info">
			<dl class="contact-info-list">
				<div class="contact-info-row">
					<dt class="contact-info-label">Email</dt>
					<dd class="contact-info-value">
						<a href={`mailto:${email}`}>{email}</a>
					</dd>
				</div>

				<div class="contact-info-row">
					<dt class="contact-info-label">Telefon</dt>
					<dd class="contact-info-value">
						<a href={phoneHref}>{phone}</a>
					</dd>
				</div>

				<div class="contact-info-row">
					<dt class="contact-info-label">Program</dt>
					<dd class="contact-info-value">
						{hours.map((h) => <p>{h.days}: {h.time}</p>)}
					</dd>
				</div>
			</dl>
		</aside>
	</div>
</section>

<style>
	.contact-form-section {
		background: var(--color-cream);
		padding: 3rem 0 4rem;
	}

	.contact-form-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}

	.contact-form-heading {
		text-align: left;
		font-size: clamp(1.9rem, 5vw, 2.75rem);
		margin-bottom: 1.75rem;
	}

	.hp-field {
		position: absolute;
		left: -10000px;
		top: auto;
		width: 1px;
		height: 1px;
		overflow: hidden;
	}

	.contact-form {
		display: flex;
		flex-direction: column;
		gap: 0.875rem;
	}

	.field input,
	.field textarea {
		width: 100%;
		padding: 0.95rem 1rem;
		background: var(--color-surface);
		border: 1px solid var(--color-line-soft);
		border-radius: 0;
		font: inherit;
		color: var(--color-ink);
		font-size: 0.9375rem;
		transition:
			border-color 0.2s ease,
			background-color 0.2s ease;
	}

	.field input::placeholder,
	.field textarea::placeholder {
		color: var(--color-mute-soft);
		opacity: 1;
	}

	.field input:focus,
	.field textarea:focus {
		outline: none;
		border-color: var(--color-ink);
	}

	.field input:user-invalid,
	.field textarea:user-invalid {
		border-color: #b14b4b;
	}

	.field textarea {
		resize: vertical;
		min-height: 8rem;
		line-height: 1.5;
	}

	.contact-error {
		font-size: 0.875rem;
		color: #8a2a2a;
		background: rgba(177, 75, 75, 0.08);
		border: 1px solid rgba(177, 75, 75, 0.35);
		padding: 0.75rem 1rem;
		margin: 0;
	}

	.contact-error a {
		text-decoration: underline;
	}

	.contact-submit {
		appearance: none;
		width: 100%;
		padding: 1.05rem 1rem;
		font-weight: 500;
		letter-spacing: 0.02em;
		font-size: 0.9375rem;
		background: var(--color-ink);
		color: #fff;
		border: 1px solid var(--color-ink);
		cursor: pointer;
		transition:
			background-color 0.2s ease,
			color 0.2s ease;
	}

	.contact-submit:hover:not(:disabled) {
		background: transparent;
		color: var(--color-ink);
	}

	.contact-submit:disabled {
		cursor: progress;
		opacity: 0.7;
	}

	.contact-success {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		padding: 2.5rem 1.5rem;
		border: 1px solid var(--color-line);
		background: var(--color-cream);
		text-align: center;
	}

	.contact-success-title {
		font-size: clamp(1.5rem, 3vw, 2rem);
		font-weight: 700;
		letter-spacing: -0.01em;
		color: var(--color-ink);
	}

	.contact-success-text {
		font-size: 1rem;
		line-height: 1.6;
		color: var(--color-ink);
		max-width: 38ch;
		margin-inline: auto;
	}

	.contact-info {
		order: -1;
	}

	.contact-info-list {
		margin: 0;
	}

	.contact-info-row {
		padding: 1rem 0;
	}

	.contact-info-label {
		font-weight: 700;
		letter-spacing: 0.06em;
		text-transform: uppercase;
		font-size: 0.9375rem;
		color: var(--color-ink);
		margin-bottom: 0.5rem;
	}

	.contact-info-value {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.6;
		color: var(--color-ink);
	}

	.contact-info-value a {
		color: inherit;
		text-decoration: none;
	}

	.contact-info-value a:hover {
		text-decoration: underline;
	}

	.contact-info-value p {
		margin: 0;
	}

	.contact-info-value p + p {
		margin-top: 0.25rem;
	}

	@media (min-width: 900px) {
		.contact-form-section {
			padding: 5rem 0 6rem;
		}

		.contact-form-grid {
			grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
			gap: 4rem;
			align-items: center;
		}

		.contact-form-side {
			padding-left: 3.4rem;
		}

		.contact-form-heading,
		.contact-form-shell {
			max-width: 40.625rem;
		}

		.contact-form-heading {
			font-size: clamp(1.5rem, 2vw, 2rem);
			text-transform: uppercase;
			letter-spacing: 0.02em;
			font-weight: 700;
			margin-bottom: 2rem;
		}

		.contact-info {
			order: 0;
		}

		.contact-form {
			gap: 1rem;
		}

		.contact-success {
			padding: 4rem 2.5rem;
		}
	}
</style>

<script>
	const SUCCESS_MS = 200;

	function initContactForm() {
		const form = document.querySelector<HTMLFormElement>('[data-contact-form]');
		if (!form || form.dataset.bound === 'true') return;
		form.dataset.bound = 'true';

		const renderedAtField = form.querySelector<HTMLInputElement>(
			'[data-rendered-at]',
		);
		if (renderedAtField) {
			renderedAtField.value = String(Date.now());
		}

		const errorBox =
			form.querySelector<HTMLParagraphElement>('[data-form-error]');
		const submitBtn = form.querySelector<HTMLButtonElement>('[data-submit-btn]');
		const btnLabel = submitBtn?.querySelector<HTMLSpanElement>('[data-btn-label]');
		const shell = form.closest<HTMLElement>('[data-form-shell]');
		const success = shell?.querySelector<HTMLElement>('[data-success]');

		const setError = (message: string | null) => {
			if (!errorBox) return;
			if (message) {
				errorBox.hidden = false;
			} else {
				errorBox.hidden = true;
			}
		};

		form.addEventListener('submit', async (event) => {
			event.preventDefault();
			setError(null);

			if (!form.checkValidity()) {
				form.reportValidity();
				return;
			}

			if (submitBtn && btnLabel) {
				submitBtn.disabled = true;
				btnLabel.textContent = 'Se trimite…';
			}

			const formData = new FormData(form);
			const payload = Object.fromEntries(formData.entries());

			try {
				const res = await fetch('/api/contact', {
					method: 'POST',
					headers: { 'Content-Type': 'application/json' },
					body: JSON.stringify(payload),
				});

				const data = (await res.json().catch(() => null)) as {
					ok?: boolean;
				} | null;

				if (!res.ok || !data?.ok) {
					throw new Error('Send failed');
				}

				if (form && success) {
					form.hidden = true;
					success.hidden = false;
					setTimeout(
						() => success.scrollIntoView({ behavior: 'smooth', block: 'center' }),
						SUCCESS_MS,
					);
				}
			} catch {
				setError('error');
				if (submitBtn && btnLabel) {
					submitBtn.disabled = false;
					btnLabel.textContent = 'Trimite';
				}
			}
		});
	}

	initContactForm();
	document.addEventListener('astro:page-load', initContactForm);
</script>
