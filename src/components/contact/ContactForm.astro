---
import { contactInfo } from "../../lib/contact";

interface Props {
  showContactInfo?: boolean;
}

const { showContactInfo = true } = Astro.props;
const { email, phone, phoneHref, hours } = contactInfo;

const fieldInput =
  "w-full py-[0.95rem] px-4 bg-surface border border-line-soft rounded-none text-ink text-[0.9375rem] transition-colors duration-200 placeholder:text-mute-soft placeholder:opacity-100 focus:outline-none focus:border-ink [&:user-invalid]:border-[#b14b4b]";
const fieldTextarea = `${fieldInput} resize-y min-h-32 leading-normal`;
---

<section class="bg-cream pt-12 pb-16 md:pt-20 md:pb-24">
  <div
    class:list={[
      "container-x grid grid-cols-1",
      showContactInfo &&
        "gap-10 md:grid-cols-[minmax(0,1.6fr)_minmax(0,1fr)] md:gap-16 md:items-center",
    ]}
  >
    <div
      class:list={[
        "md:pl-[3.4rem]",
        !showContactInfo && "mx-auto md:min-w-190",
      ]}
    >
      <h2
        class="font-bold tracking-[-0.015em] leading-[1.05] text-black text-left text-[clamp(1.9rem,5vw,2.75rem)] mb-7 md:text-[clamp(1.5rem,2vw,2rem)] md:uppercase md:tracking-[0.02em] md:mb-8 md:max-w-162.5"
      >
        trimite-ne un mesaj
      </h2>

      <div class="md:max-w-162.5" data-form-shell>
        <form
          class="flex flex-col gap-3.5 md:gap-4"
          data-contact-form
          method="post"
          action="/api/contact"
          novalidate
        >
          <!-- Honeypot: hidden from humans, bots fill it. -->
          <div
            class="absolute -left-2500 top-auto w-px h-px overflow-hidden"
            aria-hidden="true"
          >
            <label>
              Lasă acest câmp gol
              <input
                type="text"
                name="website"
                tabindex="-1"
                autocomplete="off"
              />
            </label>
          </div>

          <input type="hidden" name="renderedAt" data-rendered-at value="" />

          <div>
            <label class="sr-only" for="contact-name"> Nume & Prenume </label>
            <input
              class={fieldInput}
              id="contact-name"
              name="name"
              type="text"
              required
              autocomplete="name"
              placeholder="Nume & Prenume"
            />
          </div>

          <div>
            <label class="sr-only" for="contact-email">Email</label>
            <input
              class={fieldInput}
              id="contact-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="Email"
            />
          </div>

          <div>
            <label class="sr-only" for="contact-phone"> Nr. de telefon </label>
            <input
              class={fieldInput}
              id="contact-phone"
              name="phone"
              type="tel"
              inputmode="tel"
              autocomplete="tel"
              placeholder="Nr. de telefon"
            />
          </div>

          <div>
            <label class="sr-only" for="contact-subject">Subiect</label>
            <input
              class={fieldInput}
              id="contact-subject"
              name="subject"
              type="text"
              placeholder="Subiect"
            />
          </div>

          <div>
            <label class="sr-only" for="contact-message"> Mesajul tău </label>
            <textarea
              class={fieldTextarea}
              id="contact-message"
              name="message"
              required
              rows="5"
              placeholder="Mesajul tău"></textarea>
          </div>

          <p
            class="text-sm text-[#8a2a2a] bg-[rgba(177,75,75,0.08)] border border-[rgba(177,75,75,0.35)] py-3 px-4 m-0 [&_a]:underline"
            data-form-error
            hidden
          >
            Mesajul nu s-a trimis. Te rugăm să încerci din nou sau scrie-ne
            direct la <a href={`mailto:${email}`}>{email}</a>.
          </p>

          <button
            type="submit"
            class="appearance-none w-full py-[1.05rem] px-4 font-medium tracking-[0.02em] text-[0.9375rem] bg-ink text-white border border-ink cursor-pointer transition-colors duration-200 hover:enabled:bg-transparent hover:enabled:text-ink disabled:cursor-progress disabled:opacity-70"
            data-submit-btn
          >
            <span data-btn-label>Trimite</span>
          </button>
        </form>

        <div
          class="flex flex-col gap-3 py-10 px-6 md:py-16 md:px-10 border border-line bg-cream text-center"
          data-success
          hidden
          role="status"
          aria-live="polite"
        >
          <h3
            class="text-[clamp(1.5rem,3vw,2rem)] font-bold tracking-[-0.01em] text-ink"
          >
            Mulțumim!
          </h3>
          <p class="text-base leading-relaxed text-ink max-w-[38ch] mx-auto">
            Mesajul tău a ajuns la noi. Te contactăm în curând.
          </p>
        </div>
      </div>
    </div>

    {
      showContactInfo && (
        <aside class="order-first md:order-0">
          <dl class="m-0">
            <div class="py-4">
              <dt class="font-bold tracking-[0.06em] uppercase text-[0.9375rem] text-ink mb-2">
                Email
              </dt>
              <dd class="m-0 text-[1.0625rem] leading-relaxed text-ink [&_a]:text-inherit [&_a]:no-underline [&_a:hover]:underline">
                <a href={`mailto:${email}`}>{email}</a>
              </dd>
            </div>

            <div class="py-4">
              <dt class="font-bold tracking-[0.06em] uppercase text-[0.9375rem] text-ink mb-2">
                Telefon
              </dt>
              <dd class="m-0 text-[1.0625rem] leading-relaxed text-ink [&_a]:text-inherit [&_a]:no-underline [&_a:hover]:underline">
                <a href={phoneHref}>{phone}</a>
              </dd>
            </div>

            <div class="py-4">
              <dt class="font-bold tracking-[0.06em] uppercase text-[0.9375rem] text-ink mb-2">
                Program
              </dt>
              <dd class="m-0 text-[1.0625rem] leading-relaxed text-ink [&_p]:m-0 [&_p+p]:mt-1">
                {hours.map((h) => (
                  <p>
                    {h.days}: {h.time}
                  </p>
                ))}
              </dd>
            </div>
          </dl>
        </aside>
      )
    }
  </div>
</section>

<script>
  const SUCCESS_MS = 200;

  function initContactForm() {
    const form = document.querySelector<HTMLFormElement>("[data-contact-form]");
    if (!form || form.dataset.bound === "true") return;
    form.dataset.bound = "true";

    const renderedAtField =
      form.querySelector<HTMLInputElement>("[data-rendered-at]");
    if (renderedAtField) {
      renderedAtField.value = String(Date.now());
    }

    const errorBox =
      form.querySelector<HTMLParagraphElement>("[data-form-error]");
    const submitBtn =
      form.querySelector<HTMLButtonElement>("[data-submit-btn]");
    const btnLabel =
      submitBtn?.querySelector<HTMLSpanElement>("[data-btn-label]");
    const shell = form.closest<HTMLElement>("[data-form-shell]");
    const success = shell?.querySelector<HTMLElement>("[data-success]");

    const setError = (message: string | null) => {
      if (!errorBox) return;
      if (message) {
        errorBox.hidden = false;
      } else {
        errorBox.hidden = true;
      }
    };

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      setError(null);

      if (!form.checkValidity()) {
        form.reportValidity();
        return;
      }

      if (submitBtn && btnLabel) {
        submitBtn.disabled = true;
        btnLabel.textContent = "Se trimite…";
      }

      const formData = new FormData(form);
      const payload = Object.fromEntries(formData.entries());

      try {
        const res = await fetch("/api/contact", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });

        const data = (await res.json().catch(() => null)) as {
          ok?: boolean;
        } | null;

        if (!res.ok || !data?.ok) {
          throw new Error("Send failed");
        }

        if (form && success) {
          form.hidden = true;
          success.hidden = false;
          setTimeout(
            () =>
              success.scrollIntoView({ behavior: "smooth", block: "center" }),
            SUCCESS_MS,
          );
        }
      } catch {
        setError("error");
        if (submitBtn && btnLabel) {
          submitBtn.disabled = false;
          btnLabel.textContent = "Trimite";
        }
      }
    });
  }

  initContactForm();
  document.addEventListener("astro:page-load", initContactForm);
</script>
