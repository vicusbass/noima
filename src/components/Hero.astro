---
import Button from './Button.astro';

interface Props {
	hero: {
		video?: {
			playbackId?: string;
		};
	};
}

const { hero } = Astro.props;
const heroPlaybackId = hero.video?.playbackId;
const hasVideo = Boolean(heroPlaybackId);
const heroPosterUrl = heroPlaybackId
	? `https://image.mux.com/${heroPlaybackId}/thumbnail.webp?width=1920&time=0`
	: null;
---

<section class="hero relative isolate overflow-hidden text-white">
	<!-- Media layer -->
	<div
		class="hero-media absolute inset-0 -z-10"
		style={heroPosterUrl ? `background-image: url('${heroPosterUrl}');` : undefined}
	>
		{
			hasVideo ? (
				<mux-video
					playback-id={heroPlaybackId}
					muted
					autoplay
					loop
					playsinline
					disable-cookies
					disable-tracking
					rendition-order="desc"
					class="hero-video h-full w-full"
					style="--media-object-fit: cover;"
				></mux-video>
			) : (
				<div class="relative h-full w-full grain placeholder-media">
					<span class="asset-placeholder-chip">VIDEO PLACEHOLDER</span>
				</div>
			)
		}

		<!-- Dark gradient for text contrast on hero media -->
		<div class="absolute inset-0 bg-linear-to-b from-black/45 via-black/15 to-black/55"></div>
	</div>

	<div class="container-x hero-inner relative pt-[calc(var(--header-height)+2rem)] pb-16 md:pb-24">
		<div class="grid items-end gap-8 md:grid-cols-[1.3fr_1fr] md:gap-16">
			<h1 class="display hero-title">
				<span>PRĂJITORIE</span>
				<span>ȘI CAFEA CU SENS</span>
				<span class="sr-only">— prăjitorie de cafea de specialitate în Cluj, Noima</span>
			</h1>

			<div class="flex flex-col-reverse items-start gap-6 md:flex-col md:items-end md:gap-8 md:text-right">
				<Button href="#manifesto">DESCOPERĂ</Button>

				<p class="hero-sub">
					Cum e cafeaua făcută de oameni care trăiesc de 18 ani din cafea?
				</p>
			</div>
		</div>
	</div>
</section>

{
	hasVideo && (
		<script>
			import '@mux/mux-video';

			function initHeroVideo() {
				const player = document.querySelector<HTMLMediaElement>('.hero-video');
				if (!player) return;
				const reveal = () => player.classList.add('is-playing');
				if (!player.paused) {
					reveal();
				} else {
					player.addEventListener('playing', reveal, { once: true });
				}
			}
			initHeroVideo();
			document.addEventListener('astro:page-load', initHeroVideo);
		</script>
	)
}

<style>
	.hero {
		min-height: min(100svh, 900px);
		display: flex;
		align-items: flex-end;
	}

	.hero-media {
		background-color: #15110d;
		background-size: cover;
		background-position: center;
	}

	.placeholder-media {
		background:
			radial-gradient(
				ellipse at 30% 40%,
				rgba(215, 184, 143, 0.35) 0%,
				transparent 55%
			),
			radial-gradient(
				ellipse at 70% 70%,
				rgba(0, 0, 0, 0.4) 0%,
				transparent 60%
			),
			linear-gradient(135deg, #2a241f 0%, #15110d 100%);
	}

	.hero-video {
		display: block;
		opacity: 0;
		transition: opacity 700ms ease-out;
	}

	.hero-video.is-playing {
		opacity: 1;
	}

	.hero-title {
		font-size: clamp(2.25rem, 6vw, 4.5rem);
		line-height: 0.92;
		color: #fff;
		text-shadow: 0 4px 30px rgba(0, 0, 0, 0.25);
	}
	.hero-title span {
		display: block;
	}

	.hero-sub {
		font-size: clamp(1rem, 1.5vw, 1.25rem);
		max-width: 28ch;
		line-height: 1.45;
		color: rgba(255, 255, 255, 0.92);
	}
</style>
