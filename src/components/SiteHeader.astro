---
interface Props {
	/** Start transparent over a hero image/video; switch to cream on scroll. */
	transparent?: boolean;
}

const { transparent = false } = Astro.props;

const links = [
	{ label: 'ACASĂ', href: '/' },
	{ label: 'SHOP', href: '/shop' },
	{ label: 'DESPRE NOI', href: '/despre-noi' },
	{ label: 'B2B', href: '/b2b' },
	{ label: 'CONTACT', href: '/contact' },
];
---

<header
	data-transparent={transparent ? 'true' : 'false'}
	class:list={[
		'site-header fixed top-0 left-0 right-0 z-40 transition-colors duration-300',
		transparent ? 'is-transparent' : 'is-solid',
	]}
>
	<div class="container-x flex items-center justify-between h-[var(--header-height)]">
		<a href="/" class="flex items-center gap-2 text-2xl font-black tracking-tight logo">
			<span>noima</span>
		</a>

		<nav class="hidden md:flex items-center gap-10 desktop-nav" aria-label="Principal">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="text-[0.8125rem] font-medium tracking-[0.18em] nav-link hover:opacity-60 transition-opacity"
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="flex items-center gap-4">
			<a
				href="/cos"
				aria-label="Coș de cumpărături"
				class="cart-btn w-11 h-11 rounded-full grid place-items-center transition-colors"
			>
				<svg
					width="22"
					height="22"
					viewBox="0 0 24 24"
					fill="none"
					stroke="currentColor"
					stroke-width="1.6"
					stroke-linecap="round"
					stroke-linejoin="round"
					aria-hidden="true"
				>
					<circle cx="9" cy="21" r="1" />
					<circle cx="20" cy="21" r="1" />
					<path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.5L23 6H6" />
				</svg>
			</a>
			<button
				type="button"
				class="mobile-toggle md:hidden w-11 h-11 rounded-full grid place-items-center"
				aria-label="Deschide meniul"
				aria-expanded="false"
				aria-controls="mobile-menu"
			>
				<span class="burger">
					<span></span>
					<span></span>
					<span></span>
				</span>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="mobile-menu md:hidden"
		data-open="false"
		aria-hidden="true"
	>
		<nav class="container-x py-8 flex flex-col gap-6" aria-label="Principal mobil">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="text-2xl font-black tracking-tight"
					>
						{link.label}
					</a>
				))
			}
		</nav>
	</div>
</header>

<style>
	.site-header {
		--header-fg: #000;
		--header-bg: transparent;
		--header-border: transparent;
		color: var(--header-fg);
		background: var(--header-bg);
		border-bottom: 1px solid var(--header-border);
		backdrop-filter: none;
	}

	/* Solid (default non-hero pages, or after-scroll state) */
	.site-header.is-solid {
		--header-fg: #000;
		--header-bg: var(--color-cream);
		--header-border: var(--color-line);
	}

	/* Transparent over hero — white ink, dark tint behind for readability. */
	.site-header.is-transparent {
		--header-fg: #fff;
		--header-bg: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.55) 0%,
			rgba(0, 0, 0, 0.15) 70%,
			transparent 100%
		);
		--header-border: transparent;
	}

	/* After-scroll state flips transparent → cream */
	.site-header.is-transparent[data-scrolled="true"] {
		--header-fg: #000;
		--header-bg: var(--color-cream);
		--header-border: var(--color-line);
	}

	.cart-btn {
		color: var(--header-fg);
	}
	.site-header.is-transparent .cart-btn {
		background: rgba(255, 255, 255, 0.1);
	}
	.site-header.is-transparent[data-scrolled="true"] .cart-btn,
	.site-header.is-solid .cart-btn {
		background: rgba(0, 0, 0, 0.04);
	}
	.cart-btn:hover {
		background: rgba(0, 0, 0, 0.08);
	}
	.site-header.is-transparent:not([data-scrolled="true"]) .cart-btn:hover {
		background: rgba(255, 255, 255, 0.2);
	}

	.mobile-toggle {
		color: var(--header-fg);
		background: transparent;
	}

	.burger {
		display: inline-flex;
		flex-direction: column;
		gap: 4px;
		width: 22px;
	}
	.burger span {
		display: block;
		height: 2px;
		background: currentColor;
		transition: transform 0.25s ease, opacity 0.2s ease;
	}
	.mobile-toggle[aria-expanded="true"] .burger span:nth-child(1) {
		transform: translateY(6px) rotate(45deg);
	}
	.mobile-toggle[aria-expanded="true"] .burger span:nth-child(2) {
		opacity: 0;
	}
	.mobile-toggle[aria-expanded="true"] .burger span:nth-child(3) {
		transform: translateY(-6px) rotate(-45deg);
	}

	.mobile-menu {
		position: fixed;
		inset: var(--header-height) 0 0 0;
		background: var(--color-cream);
		color: #000;
		transform: translateY(-100%);
		transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}
	.mobile-menu[data-open="true"] {
		transform: translateY(0);
		pointer-events: auto;
	}
</style>

<script>
	const header = document.querySelector<HTMLElement>('.site-header');
	const toggle = document.querySelector<HTMLButtonElement>('.mobile-toggle');
	const menu = document.querySelector<HTMLElement>('#mobile-menu');

	if (header?.classList.contains('is-transparent')) {
		const update = () => {
			const scrolled = window.scrollY > 60;
			header.dataset.scrolled = scrolled ? 'true' : 'false';
		};
		update();
		window.addEventListener('scroll', update, { passive: true });
	}

	if (toggle && menu) {
		toggle.addEventListener('click', () => {
			const open = toggle.getAttribute('aria-expanded') === 'true';
			toggle.setAttribute('aria-expanded', open ? 'false' : 'true');
			toggle.setAttribute(
				'aria-label',
				open ? 'Deschide meniul' : 'Închide meniul',
			);
			menu.dataset.open = open ? 'false' : 'true';
			menu.setAttribute('aria-hidden', open ? 'true' : 'false');
			document.body.style.overflow = open ? '' : 'hidden';
		});
		menu.querySelectorAll('a').forEach((a) =>
			a.addEventListener('click', () => {
				toggle.setAttribute('aria-expanded', 'false');
				menu.dataset.open = 'false';
				document.body.style.overflow = '';
			}),
		);
	}
</script>
