---
import type { ShopifyProduct } from '../lib/shopify';
import ProductCard from './ProductCard.astro';

interface Props {
	products: ShopifyProduct[];
	heading?: string;
	description?: string;
}

const {
	products,
	heading = 'cafea',
	description = 'Selecții de cafea de specialitate, prăjite pentru a evidenția aromele fiecărui lot. Origini atent alese și profiluri echilibrate în fiecare ceașcă.',
} = Astro.props;
---

<section class="bg-cream">
	<div class="container-x py-20 md:py-28">
		<header class="mx-auto mb-14 max-w-2xl text-center md:mb-20">
			<h2 class="section-heading">{heading}</h2>
			<p class="mt-5 text-sm leading-relaxed text-mute md:text-base">
				{description}
			</p>
		</header>

		{
			products.length > 0 ? (
				<div
					class="grid gap-5 grid-cols-[repeat(auto-fit,minmax(240px,1fr))] data-[count='1']:grid-cols-[minmax(260px,360px)] data-[count='1']:justify-center lg:grid-cols-4 lg:data-[count='1']:grid-cols-[minmax(0,360px)] lg:data-[count='2']:grid-cols-[repeat(2,minmax(0,360px))] lg:data-[count='2']:justify-center lg:data-[count='3']:grid-cols-[repeat(3,minmax(0,360px))] lg:data-[count='3']:justify-center"
					data-count={products.length}
				>
					{products.map((product) => (
						<ProductCard product={product} />
					))}
				</div>
			) : (
				<p class="text-center text-sm text-mute">
					Produsele se încarcă în curând.
				</p>
			)
		}
	</div>
</section>
