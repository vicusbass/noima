---
import type { ShopifyProduct } from '../lib/shopify';
import ProductCard from './ProductCard.astro';

interface Props {
	products: ShopifyProduct[];
	heading?: string;
	description?: string;
}

const {
	products,
	heading = 'cafea',
	description = 'Selecții de cafea de specialitate, prăjite pentru a evidenția aromele fiecărui lot. Origini atent alese și profiluri echilibrate în fiecare ceașcă.',
} = Astro.props;
---

<section class="featured-products">
	<div class="container-x py-20 md:py-28">
		<header class="max-w-2xl mx-auto text-center mb-14 md:mb-20">
			<h2 class="featured-heading">{heading}</h2>
			<p class="mt-5 text-sm md:text-base text-[var(--color-mute)] leading-relaxed">
				{description}
			</p>
		</header>

		{
			products.length > 0 ? (
				<div class="products-grid" data-count={products.length}>
					{products.map((product) => (
						<ProductCard product={product} />
					))}
				</div>
			) : (
				<p class="text-center text-sm text-[var(--color-mute)]">
					Produsele se încarcă în curând.
				</p>
			)
		}
	</div>
</section>

<style>
	.featured-products {
		background: var(--color-cream);
	}

	.featured-heading {
		font-size: clamp(2rem, 4vw, 3.25rem);
		font-weight: 700;
		letter-spacing: -0.01em;
	}

	.products-grid {
		display: grid;
		gap: 1.25rem;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}

	/* When only one product exists (current Shopify state), don't stretch it
	   across the whole row — center and cap the width. */
	.products-grid[data-count="1"] {
		grid-template-columns: minmax(260px, 360px);
		justify-content: center;
	}

	@media (min-width: 1024px) {
		.products-grid {
			grid-template-columns: repeat(4, minmax(0, 1fr));
		}
		.products-grid[data-count="1"] {
			grid-template-columns: minmax(0, 360px);
		}
		.products-grid[data-count="2"] {
			grid-template-columns: repeat(2, minmax(0, 360px));
			justify-content: center;
		}
		.products-grid[data-count="3"] {
			grid-template-columns: repeat(3, minmax(0, 360px));
			justify-content: center;
		}
	}
</style>
