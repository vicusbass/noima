---
import { Image } from 'astro:assets';
import Bird from '../assets/main/bird.png';
import Button from './Button.astro';

interface Props {
	heading?: string;
	paragraphs?: string[];
	ctaLabel?: string;
	ctaHref?: string;
}

const {
	heading = 'de ce există noima?',
	paragraphs = [
		'După 18 ani în distribuția de cafea, am făcut pasul spre tine. Pentru că vrem să ducem până la capăt experiența ospitalității.',
		'Nu suntem doar o altă cafenea, ci locul în care învățăm împreună ce înseamnă o cafea bună, uniți într-o comunitate cu valori și pasiuni comune.',
		'Dacă ți se pune pata pe cafeaua noastră, o poți lua acasă. Nu doar pentru tine, ci și pentru prietenii tăi, care vor înțelege de ce.',
	],
	ctaLabel = 'DESCOPERĂ',
	ctaHref = '/despre-noi',
} = Astro.props;
---

<section id="manifesto" class="why-section py-16 md:py-24">
  <div class="container-x">
    <h2 class="display-lower why-heading">{heading}</h2>
  </div>

  <div class="container-x why-panel-wrap">
    <div class="why-panel">
      <div class="why-illu" aria-hidden="true">
        <Image
          src={Bird}
          alt=""
          widths={[480, 800, 1200, 1600, 2000]}
          sizes="(min-width: 900px) 50vw, 100vw"
          class="bird-img"
        />
      </div>

      <div class="why-copy">
        {paragraphs.map((p) => <p>{p}</p>)}
        <Button href={ctaHref} variant="dark" class="why-cta">{ctaLabel}</Button
        >
      </div>
    </div>
  </div>
</section>

<style>
  .why-heading {
    font-size: clamp(2.375rem, 5vw, 6rem);
    text-align: center;
    color: #000;
    margin-bottom: 1.5rem;
  }

  .why-panel {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .why-illu {
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    overflow: hidden;
  }

  .bird-img {
    display: block;
    width: 150%;
    max-width: none;
    height: auto;
    margin-block: -60vw -50vw;
    margin-inline: -25%;
    mix-blend-mode: multiply;
  }

  .why-copy {
    display: flex;
    flex-direction: column;
  }

  .why-copy p {
    font-size: 0.875rem;
    line-height: 1.7;
    color: #000;
  }

  .why-copy p + p {
    margin-top: 1.5rem;
  }

  .why-cta {
    align-self: flex-start;
    margin-top: 2rem;
  }

  @media (min-width: 900px) {
    .why-heading {
      margin-bottom: 6rem;
    }

    .why-panel {
      background: #f8f5ed;
      height: 560px;
      overflow: visible;
      display: block;
    }

    .why-illu {
      position: absolute;
      top: -160px;
      bottom: 0;
      left: -10%;
      width: 70%;
      margin-inline: 0;
      overflow: hidden;
    }

    .bird-img {
      position: absolute;
      top: 48%;
      left: -2.5%;
      width: 95%;
      height: auto;
      max-width: none;
      margin-block: 0;
      margin-inline: 0;
      transform: translateY(-50%);
    }

    .why-copy {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: 45%;
      padding-right: 5rem;
      justify-content: center;
    }

    .why-copy p {
      font-size: 1.125rem;
      line-height: 1.8;
      max-width: 50ch;
    }

    .why-copy p + p {
      margin-top: 3.3rem;
    }

    .why-cta {
      margin-top: 3rem;
    }
  }
</style>
