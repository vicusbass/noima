---
import { Image } from 'astro:assets';
import Bird from '../assets/main/bird.png';
import BirdNoBeak from '../assets/main/bird-no-beak.png';
import Button from './Button.astro';

interface Props {
	heading?: string;
	paragraphs?: string[];
	ctaLabel?: string;
	ctaHref?: string;
}

const {
	heading = 'de ce există noima?',
	paragraphs = [
		'După 18 ani în distribuția de cafea, am făcut pasul spre tine. Pentru că vrem să ducem până la capăt experiența ospitalității.',
		'Nu suntem doar o altă cafenea, ci locul în care învățăm împreună ce înseamnă o cafea bună, uniți într-o comunitate cu valori și pasiuni comune.',
		'Dacă ți se pune pata pe cafeaua noastră, o poți lua acasă. Nu doar pentru tine, ci și pentru prietenii tăi, care vor înțelege de ce.',
	],
	ctaLabel = 'DESCOPERĂ',
	ctaHref = '/despre-noi',
} = Astro.props;
---

<section id="manifesto" class="py-16 md:py-24">
  <div class="container-x">
    <h2 class="section-heading mb-6 md:mb-24">{heading}</h2>
  </div>

  <div class="container-x">
    <div class="why-panel relative flex flex-col gap-2 md:block md:h-[560px] md:overflow-visible md:bg-cream">
      <div
        class="grid w-screen mx-[calc(50%-50vw)] overflow-clip md:absolute md:-top-40 md:bottom-0 md:-left-[10%] md:mx-0 md:w-[70%]"
        aria-hidden="true"
      >
        <Image
          src={BirdNoBeak}
          alt=""
          widths={[480, 800, 1200, 1600, 2000]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class="block w-[150%] max-w-none h-auto -mt-[60vw] -mb-[50vw] -mx-[25%] mix-blend-multiply col-start-1 row-start-1 md:absolute md:top-[48%] md:-left-[2.5%] md:m-0 md:h-auto md:w-[95%] md:max-w-none md:-translate-y-1/2"
        />
        <Image
          src={Bird}
          alt=""
          widths={[480, 800, 1200, 1600, 2000]}
          sizes="(min-width: 768px) 50vw, 100vw"
          class="bird-img-beak block w-[150%] max-w-none h-auto -mt-[60vw] -mb-[50vw] -mx-[25%] mix-blend-multiply col-start-1 row-start-1 md:absolute md:top-[48%] md:-left-[2.5%] md:m-0 md:h-auto md:w-[95%] md:max-w-none md:-translate-y-1/2"
        />
      </div>

      <div class="flex flex-col [&_p+p]:mt-6 md:absolute md:inset-y-0 md:right-0 md:w-[45%] md:justify-center md:pr-20 md:[&_p]:max-w-[50ch] md:[&_p+p]:mt-[3.3rem]">
        {paragraphs.map((p) => <p class="body-copy">{p}</p>)}
        <Button href={ctaHref} variant="dark" class="self-start mt-8 md:mt-12">{ctaLabel}</Button
        >
      </div>
    </div>
  </div>
</section>

<style>
  @supports (animation-timeline: view()) {
    .bird-img-beak {
      opacity: 0;
      animation: bird-beak-fade-in linear both;
      animation-timeline: view();
      animation-range: entry 50% cover 50%;
    }

    @media (min-width: 768px) {
      .bird-img-beak {
        animation-range: entry 0% entry 80%;
      }
    }
  }

  @keyframes bird-beak-fade-in {
    to {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .bird-img-beak {
      opacity: 1;
      animation: none;
    }
  }
</style>
