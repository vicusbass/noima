{% doc %}
  @prompt
    load Figtree from Google with full unicode support
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Figtree:ital,wght@0,300..900;1,300..900&display=swap&subset=latin,latin-ext,cyrillic,cyrillic-ext,greek,greek-ext,vietnamese" rel="stylesheet">

{% style %}
  .ai-figtree-font-loader-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-figtree-font-loader-{{ ai_gen_id }} * {
    font-family: 'Figtree', sans-serif;
  }

  .ai-figtree-font-content-{{ ai_gen_id }} {
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-figtree-font-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 16px 0;
  }

  .ai-figtree-font-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    font-weight: {{ block.settings.text_weight }};
    line-height: 1.6;
  }
{% endstyle %}

<figtree-font-loader-{{ ai_gen_id }}
  class="ai-figtree-font-loader-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-figtree-font-content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-figtree-font-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    {% if block.settings.text != blank %}
      <div class="ai-figtree-font-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
    {% endif %}
  </div>
</figtree-font-loader-{{ ai_gen_id }}>

<script>
  (function() {
    class FigtreeFontLoader{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(() => {
            this.style.opacity = '1';
          });
        }
      }
    }

    customElements.define('figtree-font-loader-{{ ai_gen_id }}', FigtreeFontLoader{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Figtree font loader",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Figtree Font Example"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>This text uses the Figtree font family from Google Fonts with full unicode support including Latin, Cyrillic, Greek, Vietnamese and extended character sets.</p>"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Heading weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra bold"
        },
        {
          "value": "900",
          "label": "Black"
        }
      ],
      "default": "700"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_weight",
      "label": "Text weight",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Regular"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semibold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "400"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f3f3f3"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Figtree font loader"
    }
  ]
}
{% endschema %}
