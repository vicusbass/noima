{%- style -%}
  .footer-noima {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .footer-noima__back-to-top {
    margin: 0 3rem 4rem;
    padding: 2rem 3rem;
    background-color: rgba(var(--color-foreground), 0.04);
    border: none;
    border-radius: 0.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    width: calc(100% - 6rem);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 1.4rem;
    color: rgb(var(--color-foreground));
    cursor: pointer;
    font-family: inherit;
    transition: background-color 0.2s ease;
  }

  .footer-noima__back-to-top:hover {
    background-color: rgba(var(--color-foreground), 0.08);
  }

  .footer-noima__back-to-top svg {
    width: 1.4rem;
    height: 1.4rem;
  }

  @media screen and (min-width: 750px) {
    .footer-noima__back-to-top {
      display: none;
    }
  }

  .footer-noima__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    padding: 0 3rem;
  }

  @media screen and (min-width: 990px) {
    .footer-noima__inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr);
      gap: 6rem;
    }
  }

  .footer-noima__brand-link {
    display: inline-block;
    text-decoration: none;
  }

  .footer-noima__brand-logo {
    display: block;
    max-width: 18rem;
    height: auto;
  }

  .footer-noima__social {
    display: flex;
    gap: 2rem;
    margin: 2.4rem 0;
    align-items: center;
  }

  .footer-noima__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: rgba(var(--color-foreground), 0.7);
    transition: color 0.2s ease;
  }

  .footer-noima__social a:hover {
    color: rgb(var(--color-foreground));
  }

  .footer-noima__social svg {
    width: 2.4rem;
    height: 2.4rem;
    fill: currentColor;
  }

  .footer-noima__tagline {
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 1.3rem;
    line-height: 1.6;
    color: rgba(var(--color-foreground), 0.7);
    margin: 0;
  }

  .footer-noima__columns {
    display: grid;
    grid-template-columns: repeat(3, auto);
    column-gap: 6rem;
    row-gap: 2rem;
    justify-content: end;
  }

  @media screen and (max-width: 749px) {
    .footer-noima__brand {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .footer-noima__social {
      justify-content: center;
    }

    .footer-noima__columns {
      grid-template-columns: 1fr;
      gap: 2.4rem;
      justify-content: center;
      text-align: center;
    }

    .footer-noima__column--menu,
    .footer-noima__column--contact {
      display: none;
    }
  }

  .footer-noima__column-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-noima__column-list li {
    margin-bottom: 1.6rem;
    line-height: 1.4;
  }

  .footer-noima__column-list li:last-child {
    margin-bottom: 0;
  }

  .footer-noima__column-list a {
    text-decoration: none;
    color: rgba(var(--color-foreground), 0.7);
    transition: color 0.2s ease;
  }

  .footer-noima__column-list a:hover {
    color: rgb(var(--color-foreground));
  }

  .footer-noima__anpc {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.6rem;
    margin-top: 4rem;
    padding: 0 3rem;
  }

  .footer-noima__anpc a {
    display: inline-block;
    line-height: 0;
  }

  .footer-noima__anpc img {
    display: block;
    height: 4.2rem;
    width: auto;
  }

  @media screen and (max-width: 749px) {
    .footer-noima__anpc {
      justify-content: center;
    }
  }

  .footer-noima__bottom {
    margin-top: 4rem;
    padding: 2rem 3rem 0;
    border-top: 0.1rem solid rgba(var(--color-foreground), 0.1);
    font-size: 1.2rem;
    color: rgba(var(--color-foreground), 0.5);
  }

  .footer-noima__bottom > * {
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .footer-noima__bottom {
      text-align: center;
    }
  }
{%- endstyle -%}

<footer class="footer-noima color-{{ section.settings.color_scheme }} gradient">
  {%- if section.settings.show_back_to_top -%}
    <button
      type="button"
      class="footer-noima__back-to-top"
      aria-label="Înapoi sus"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' });"
    >
      <span>Înapoi sus</span>
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="18 15 12 9 6 15"/>
      </svg>
    </button>
  {%- endif -%}

  <div class="footer-noima__inner">
    <div class="footer-noima__brand">
      {%- if section.settings.logo != blank -%}
        <a href="{{ routes.root_url }}" class="footer-noima__brand-link">
          {%- assign logo_alt = section.settings.logo.alt | default: shop.name | escape -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              class: 'footer-noima__brand-logo',
              alt: logo_alt,
              loading: 'lazy',
              widths: '180, 360, 540',
              sizes: '180px'
          }}
        </a>
      {%- else -%}
        <a href="{{ routes.root_url }}" class="footer-noima__brand-link"><span class="h2">{{ shop.name }}</span></a>
      {%- endif -%}

      <div class="footer-noima__social">
        {%- if section.settings.facebook_url != blank -%}
          <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96A10 10 0 0 0 22 12.06C22 6.53 17.5 2.04 12 2.04Z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.instagram_url != blank -%}
          <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M7.8 2H16.2C19.4 2 22 4.6 22 7.8V16.2A5.8 5.8 0 0 1 16.2 22H7.8C4.6 22 2 19.4 2 16.2V7.8A5.8 5.8 0 0 1 7.8 2M7.6 4A3.6 3.6 0 0 0 4 7.6V16.4C4 18.39 5.61 20 7.6 20H16.4A3.6 3.6 0 0 0 20 16.4V7.6C20 5.61 18.39 4 16.4 4H7.6M17.25 5.5A1.25 1.25 0 0 1 18.5 6.75A1.25 1.25 0 0 1 17.25 8A1.25 1.25 0 0 1 16 6.75A1.25 1.25 0 0 1 17.25 5.5M12 7A5 5 0 0 1 17 12A5 5 0 0 1 12 17A5 5 0 0 1 7 12A5 5 0 0 1 12 7M12 9A3 3 0 0 0 9 12A3 3 0 0 0 12 15A3 3 0 0 0 15 12A3 3 0 0 0 12 9Z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.whatsapp_url != blank -%}
          <a href="{{ section.settings.whatsapp_url }}" target="_blank" rel="noopener" aria-label="WhatsApp">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91C2.13 13.66 2.59 15.36 3.45 16.86L2.05 22L7.3 20.62C8.75 21.41 10.38 21.83 12.04 21.83C17.5 21.83 21.95 17.38 21.95 11.92C21.95 9.27 20.92 6.78 19.05 4.91C17.18 3.03 14.69 2 12.04 2M12.05 3.67C14.25 3.67 16.31 4.53 17.87 6.09C19.42 7.65 20.28 9.72 20.28 11.92C20.28 16.46 16.58 20.15 12.04 20.15C10.56 20.15 9.11 19.76 7.85 19L7.55 18.83L4.43 19.65L5.26 16.61L5.06 16.29C4.24 15 3.8 13.47 3.8 11.91C3.81 7.37 7.5 3.67 12.05 3.67M8.53 7.33C8.37 7.33 8.1 7.39 7.87 7.64C7.65 7.89 7 8.5 7 9.71C7 10.93 7.89 12.1 8 12.27C8.14 12.44 9.76 14.94 12.25 16C12.84 16.27 13.3 16.42 13.66 16.53C14.25 16.72 14.79 16.69 15.22 16.63C15.7 16.56 16.68 16.03 16.89 15.45C17.1 14.87 17.1 14.38 17.04 14.27C16.97 14.17 16.81 14.1 16.56 13.98C16.31 13.86 15.09 13.26 14.87 13.18C14.64 13.1 14.5 13.06 14.31 13.31C14.13 13.55 13.67 14.1 13.53 14.27C13.38 14.44 13.24 14.46 13 14.34C12.75 14.21 11.97 13.96 11.04 13.13C10.32 12.49 9.84 11.7 9.7 11.46C9.56 11.21 9.68 11.08 9.81 10.96C9.93 10.85 10.06 10.67 10.19 10.53C10.31 10.4 10.35 10.3 10.43 10.14C10.51 9.97 10.47 9.83 10.41 9.71C10.35 9.59 9.86 8.36 9.65 7.87C9.45 7.39 9.24 7.46 9.09 7.45C8.94 7.45 8.78 7.44 8.61 7.44L8.53 7.33Z"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.email_url != blank -%}
          <a href="mailto:{{ section.settings.email_url }}" aria-label="Email">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
            </svg>
          </a>
        {%- endif -%}
      </div>

      {%- if section.settings.tagline != blank -%}
        <p class="footer-noima__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    <div class="footer-noima__columns">
      {%- if section.settings.menu != blank -%}
        <div class="footer-noima__column footer-noima__column--menu">
          <ul class="footer-noima__column-list" role="list">
            {%- for link in section.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

      <div class="footer-noima__column footer-noima__column--contact">
        <ul class="footer-noima__column-list" role="list">
          {%- if section.settings.contact_email != blank -%}
            <li>
              <a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.contact_phone != blank -%}
            <li>
              <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}">{{ section.settings.contact_phone }}</a>
            </li>
          {%- endif -%}
          {%- if section.settings.contact_address != blank -%}
            <li>{{ section.settings.contact_address }}</li>
          {%- endif -%}
          {%- if section.settings.contact_city != blank -%}
            <li>{{ section.settings.contact_city }}</li>
          {%- endif -%}
        </ul>
      </div>

      {%- if section.settings.legal_menu != blank -%}
        <div class="footer-noima__column">
          <ul class="footer-noima__column-list" role="list">
            {%- for link in section.settings.legal_menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title | escape }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="footer-noima__anpc">
    <a
      href="https://ec.europa.eu/consumers/odr/main/index.cfm?event=main.home2.show&amp;lng=RO"
      target="_blank"
      rel="noopener"
      aria-label="ANPC — Soluționarea online a litigiilor (SOL)"
    >
      <img
        src="{{ 'anpc-sol.png' | asset_url }}"
        alt="ANPC — Soluționarea online a litigiilor (SOL)"
        width="500"
        height="124"
        loading="lazy"
      >
    </a>
    <a
      href="https://anpc.ro/ce-este-sal/"
      target="_blank"
      rel="noopener"
      aria-label="ANPC — Soluționarea alternativă a litigiilor (SAL)"
    >
      <img
        src="{{ 'anpc-sal.webp' | asset_url }}"
        alt="ANPC — Soluționarea alternativă a litigiilor (SAL)"
        width="500"
        height="124"
        loading="lazy"
      >
    </a>
  </div>

  {%- if section.settings.bottom_text != blank -%}
    <div class="footer-noima__bottom">
      {{ section.settings.bottom_text }}
    </div>
  {%- endif -%}
</footer>

{% schema %}
{
  "name": "Subsol Noima",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Slogan",
      "default": "PRĂJITORIE ȘI CAFEA CU SENS"
    },
    {
      "type": "header",
      "content": "Rețele sociale"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "URL Facebook",
      "info": "ex. https://facebook.com/noima"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "URL Instagram",
      "info": "ex. https://instagram.com/noima"
    },
    {
      "type": "text",
      "id": "whatsapp_url",
      "label": "URL WhatsApp",
      "info": "ex. https://wa.me/40755123456"
    },
    {
      "type": "text",
      "id": "email_url",
      "label": "Adresă email (icon)",
      "info": "Adresa folosită pentru iconul de email"
    },
    {
      "type": "header",
      "content": "Coloana 1 — Meniu"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Meniu",
      "default": "footer"
    },
    {
      "type": "header",
      "content": "Coloana 2 — Contact"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "contact@noima.ro"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Telefon",
      "default": "0755123456"
    },
    {
      "type": "text",
      "id": "contact_address",
      "label": "Adresă",
      "default": "Strada Bobâlnei, nr. 1"
    },
    {
      "type": "text",
      "id": "contact_city",
      "label": "Oraș",
      "default": "Cluj-Napoca"
    },
    {
      "type": "header",
      "content": "Coloana 3 — Linkuri legale"
    },
    {
      "type": "link_list",
      "id": "legal_menu",
      "label": "Meniu legal"
    },
    {
      "type": "header",
      "content": "Subsol"
    },
    {
      "type": "richtext",
      "id": "bottom_text",
      "label": "Text subsol",
      "default": "<p>design by Symbold</p>"
    },
    {
      "type": "header",
      "content": "Aspect"
    },
    {
      "type": "checkbox",
      "id": "show_back_to_top",
      "label": "Afișează butonul „Înapoi sus” pe mobil",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Schemă de culori",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Spațiere sus",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Spațiere jos",
      "default": 36
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  }
}
{% endschema %}
